{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chimaera",
  "version": "0.0.1",
  "identifier": "dev.chimaera.app",
  "build": {
    "frontendDist": "assets",
    "beforeBuildCommand": "cd ../../web-ui && npm install && npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "shortDescription": "Agent-native IDE for local and HPC work",
    "icon": ["icons/icon.icns", "icons/icon.png"]
  }
}
