{
  "identifier": "daemon-ui",
  "description": "Every window is the daemon-served UI — the local daemon or an ssh tunnel, always on loopback — and gets the shell bridge (hosts, tunnels, windows).",
  "windows": ["*"],
  "local": true,
  "remote": {
    "urls": ["http://127.0.0.1:*", "http://localhost:*"]
  },
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-set-title",
    "allow-list-hosts",
    "allow-add-host",
    "allow-remove-host",
    "allow-connect-host",
    "allow-disconnect-host",
    "allow-end-host-sessions",
    "allow-shutdown-host",
    "allow-local-state",
    "allow-update-local-daemon",
    "allow-remote-workspaces",
    "allow-remote-compute-sessions",
    "allow-launch-compute-session",
    "allow-cancel-compute-session",
    "allow-connect-compute-session",
    "allow-open-window",
    "allow-report-window-scope",
    "allow-check-app-update",
    "allow-begin-update",
    "allow-shell-build",
    "allow-write-clipboard",
    "allow-set-caffeinate",
    "allow-caffeinate-state",
    "allow-answer-askpass",
    "allow-list-askpass"
  ]
}
