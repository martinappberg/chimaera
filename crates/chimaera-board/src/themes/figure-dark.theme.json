    "subtitle": {
      "family": ["Geist", "Arial", "Helvetica Neue", "Helvetica", "Liberation Sans", "DejaVu Sans", "Inter", "sans-serif"],
      "size": 10,
      "weight": 400,
      "color": "@muted",
      "minPt": 6,
      "lineHeight": 1.25
    },
    "body": {
      "family": ["Geist", "Arial", "Helvetica Neue", "Helvetica", "Liberation Sans", "DejaVu Sans", "Inter", "sans-serif"],
