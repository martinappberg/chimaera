{
  "id": "figure-light",
  "name": "Figure — light",
  "dark": false,
  "palette": {
    "bg": "#fdfdfc",
    "surface": "#f4f3f0",
    "fg": "#16181c",
    "body": "#24272c",
    "muted": "#5b6470",
    "accent1": "#0b6bcb",
    "edge": "#e3e2dd",
    "axis": "#3a3f46",
    "grid": "#ebeae5",
    "cat1": "#0072b2",
    "cat2": "#d55e00",
    "cat3": "#009e73",
    "cat4": "#cc79a7",
    "cat5": "#56b4e9",
    "cat6": "#e69f00",
    "cat7": "#f0e442"
  },
  "type": {
    "title": {
      "family": ["Arimo", "Arial", "Helvetica Neue", "Helvetica", "Liberation Sans", "DejaVu Sans", "Inter", "sans-serif"],
      "size": 14,
      "weight": 700,
      "color": "@fg",
      "minPt": 7,
      "lineHeight": 1.2,
      "tracking": -0.1
    },
    "heading": {
      "family": ["Arimo", "Arial", "Helvetica Neue", "Helvetica", "Liberation Sans", "DejaVu Sans", "Inter", "sans-serif"],
      "size": 11,
      "weight": 700,
      "color": "@fg",
      "minPt": 6,
      "lineHeight": 1.2
    },
    "subtitle": {
      "family": ["Arimo", "Arial", "Helvetica Neue", "Helvetica", "Liberation Sans", "DejaVu Sans", "Inter", "sans-serif"],
      "size": 10,
      "weight": 400,
      "color": "@muted",
      "minPt": 6,
      "lineHeight": 1.25
    },
    "body": {
      "family": ["Arimo", "Arial", "Helvetica Neue", "Helvetica", "Liberation Sans", "DejaVu Sans", "Inter", "sans-serif"],
      "size": 9,
      "weight": 400,
      "color": "@body",
      "minPt": 5,
      "lineHeight": 1.35
    },
    "caption": {
      "family": ["Arimo", "Arial", "Helvetica Neue", "Helvetica", "Liberation Sans", "DejaVu Sans", "Inter", "sans-serif"],
      "size": 7,
      "weight": 400,
      "color": "@muted",
      "minPt": 5,
      "lineHeight": 1.3
    },
    "label": {
      "family": ["Arimo", "Arial", "Helvetica Neue", "Helvetica", "Liberation Sans", "DejaVu Sans", "Inter", "sans-serif"],
      "size": 7,
      "weight": 400,
      "color": "@muted",
      "minPt": 5,
      "lineHeight": 1.2
    },
    "code": {
      "family": ["JetBrains Mono", "SF Mono", "Menlo", "Consolas", "Liberation Mono", "DejaVu Sans Mono", "monospace"],
      "size": 8,
      "weight": 400,
      "color": "@body",
      "minPt": 5,
      "lineHeight": 1.4
    }
  },
  "spacing": {
    "grid": 8,
    "margin": [8, 8, 8, 8],
    "gap": 8
  },
  "chart": {
    "categorical": ["@cat1", "@cat2", "@cat3", "@cat4", "@cat5", "@cat6", "@cat7"],
    "axis": "@axis",
    "grid": "@grid",
    "axisWidth": 0.5,
    "seriesWidth": 1,
    "barRatio": 0.68
  }
}
