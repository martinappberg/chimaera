{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "chimaerad",
      "runtimeExecutable": "cargo",
      "runtimeArgs": ["run", "-p", "chimaera", "--", "serve", "--port", "9700"],
      "port": 9700
    },
    {
      "comment": "This worktree's daemon on an isolated state dir + an auto-assigned port. Use this (not chimaerad) when other worktrees/chats may have a daemon up. See the develop skill.",
      "name": "chimaerad-isolated",
      "runtimeExecutable": "bash",
      "runtimeArgs": [".claude/skills/develop/serve-isolated.sh"],
      "autoPort": true
    },
    {
      "comment": "The public GitHub Pages site (site/) as plain static files.",
      "name": "site",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "4173", "--directory", "site"],
      "port": 4173
    },
    {
      "name": "web-ui",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web-ui", "run", "dev", "--", "--port", "5173", "--strictPort"],
      "port": 5173
    },
    {
      "name": "web-ui-sandbox",
      "runtimeExecutable": "env",
      "runtimeArgs": [
        "CHIMAERA_DEV_TARGET=http://127.0.0.1:9741",
        "npm",
        "--prefix",
        "web-ui",
        "run",
        "dev",
        "--",
        "--port",
        "5174",
        "--strictPort"
      ],
      "port": 5174
    }
  ]
}
